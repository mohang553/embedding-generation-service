# --- Pinecone Configuration ---
# Your Pinecone API Key (from app.pinecone.io)
PINECONE_API_KEY=your_pinecone_api_key_here

# The name of your index (e.g., ecommerce-index)
PINECONE_INDEX_NAME=ecommerce-index

# --- OSS LLM Configuration ---
# The base URL for the GPT-OSS model deployment
# Example: http://3.109.63.164/gptoss/v1
OSS_LLM_URL=http://your_llm_server_ip/gptoss/v1

# The specific model name to use
# Example: gpt-oss:20b
OSS_LLM_MODEL=gpt-oss:20b

# --- Embedding Configuration ---
# The HuggingFace model used for generating embeddings
# Standard for 768 dimensions: all-mpnet-base-v2
EMBEDDING_MODEL=all-mpnet-base-v2
